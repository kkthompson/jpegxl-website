<script>
  const desktopItems = Array.from(document.querySelectorAll<HTMLElement>('.navbar-desktop-item'));
  const mobileTrigger = document.querySelector<HTMLButtonElement>('#navbar-mobile-trigger');
  const mobileMenu = document.querySelector<HTMLElement>('#navbar-mobile-menu');
  const mobileClose = document.querySelector<HTMLButtonElement>('#navbar-mobile-close');
  const mobileBar = document.querySelector<HTMLElement>('.navbar-container-menu-top');
  const pageWrapper = document.querySelector<HTMLElement>('.page-wrapper');
  const skipNav = document.querySelector<HTMLElement>('.skip-nav');
  const jxlDecoderInfos = Array.from(document.querySelectorAll<HTMLElement>('[data-jxl-decoder-info]'));
  const jxlDecoderTriggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-jxl-decoder-info] button'),
  );
  const mobileMedia = window.matchMedia('(max-width: 900px)');
  let lockedScrollY = 0;

  function setBackgroundInert(inert: boolean) {
    [pageWrapper, skipNav].forEach((element) => {
      if (!element) return;
      element.toggleAttribute('inert', inert);
    });
  }

  function getMobileMenuFocusable() {
    if (!mobileMenu) return [];
    return Array.from(
      mobileMenu.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    ).filter((element) => !element.hasAttribute('hidden'));
  }

  function setDesktopMenu(item: HTMLElement, open: boolean) {
    const trigger = item.querySelector<HTMLButtonElement>('.navbar-desktop-trigger');
    item.classList.toggle('is-open', open);
    trigger?.setAttribute('aria-expanded', String(open));
  }

  function closeDesktopMenus(except?: HTMLElement) {
    desktopItems.forEach((item) => {
      if (item !== except) setDesktopMenu(item, false);
    });
  }

  function setJxlDecoderMessage(trigger: HTMLButtonElement, open: boolean) {
    const message = trigger.closest<HTMLElement>('[data-jxl-decoder-info]')?.querySelector<HTMLElement>('[role="tooltip"]');
    trigger.setAttribute('aria-expanded', String(open));
    if (message) message.hidden = !open;
  }

  function closeJxlDecoderMessages(except?: HTMLButtonElement) {
    jxlDecoderTriggers.forEach((trigger) => {
      if (trigger !== except) setJxlDecoderMessage(trigger, false);
    });
  }

  function supportsNativeJxl() {
    return new Promise<boolean>((resolve) => {
      // Cache the verdict per tab session: browsers without native support
      // fail the probe in a few ms, but browsers WITH support must download
      // and decode it — re-racing the timeout on every page load is how the
      // button flickers on in Safari over slow connections.
      let cached: string | null = null;
      try {
        cached = window.sessionStorage.getItem('jxl-native');
      } catch {}
      if (cached !== null) return resolve(cached === '1');

      const probe = new Image();
      let settled = false;
      const finish = (supported: boolean, remember: boolean) => {
        if (settled) return;
        settled = true;
        if (remember) {
          try {
            window.sessionStorage.setItem('jxl-native', supported ? '1' : '0');
          } catch {}
        }
        resolve(supported);
      };

      probe.onload = () => finish(true, true);
      probe.onerror = () => finish(false, true);
      // Safari can natively decode JXL files but does not accept the compact
      // hand-crafted data-URL probe used here previously. Keep this detached
      // so JXL.js cannot intercept it, and use a tiny (~0.5 KB) conventional
      // cjxl-encoded file so slow networks cannot blow the deadline the way
      // the previous 46 KB probe could. A timeout is not remembered — it says
      // nothing about the browser, only about the connection.
      probe.src = '/images/jxl-probe.jxl';
      window.setTimeout(() => finish(false, false), 4000);
    });
  }

  async function showJxlDecoderInfoWhenNeeded() {
    if (!document.documentElement.hasAttribute('data-jxl-wasm-fallback') || !jxlDecoderInfos.length) return;
    if (!(await supportsNativeJxl())) jxlDecoderInfos.forEach((info) => (info.hidden = false));
  }

  desktopItems.forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.navbar-desktop-trigger');
    const firstLink = item.querySelector<HTMLAnchorElement>('.navbar-desktop-dropdown a');
    if (!trigger) return;

    trigger.addEventListener('click', () => {
      const willOpen = trigger.getAttribute('aria-expanded') !== 'true';
      closeDesktopMenus(item);
      setDesktopMenu(item, willOpen);
    });

    trigger.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        closeDesktopMenus(item);
        setDesktopMenu(item, true);
        firstLink?.focus();
      }
      if (event.key === 'Escape') {
        setDesktopMenu(item, false);
      }
    });

    item.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setDesktopMenu(item, false);
        trigger.focus();
      }
    });

    item.addEventListener('focusout', () => {
      requestAnimationFrame(() => {
        if (!item.contains(document.activeElement)) setDesktopMenu(item, false);
      });
    });
  });

  jxlDecoderTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const willOpen = trigger.getAttribute('aria-expanded') !== 'true';
      closeJxlDecoderMessages(trigger);
      setJxlDecoderMessage(trigger, willOpen);
    });
  });

  function setPageScrollLocked(locked: boolean) {
    const body = document.body;
    if (locked) {
      if (body.classList.contains('mobile-menu-open')) return;
      lockedScrollY = window.scrollY;
      body.style.top = `-${lockedScrollY}px`;
      body.classList.add('mobile-menu-open');
      return;
    }

    if (!body.classList.contains('mobile-menu-open')) return;
    body.classList.remove('mobile-menu-open');
    body.style.top = '';
    window.scrollTo(0, lockedScrollY);
  }

  function setMobileMenu(open: boolean, moveFocus = false) {
    if (!mobileTrigger || !mobileMenu) return;
    if (open && mobileBar) {
      mobileMenu.style.setProperty('--mobile-menu-top', `${mobileBar.getBoundingClientRect().height}px`);
    }
    mobileMenu.hidden = !open;
    mobileTrigger.setAttribute('aria-expanded', String(open));
    setPageScrollLocked(open && mobileMedia.matches);
    setBackgroundInert(open && mobileMedia.matches);
    if (open && moveFocus) mobileClose?.focus();
    if (!open && moveFocus) mobileTrigger.focus();
  }

  mobileTrigger?.addEventListener('click', () => {
    setMobileMenu(mobileTrigger.getAttribute('aria-expanded') !== 'true', true);
  });

  mobileClose?.addEventListener('click', () => setMobileMenu(false, true));

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMobileMenu(false));
  });

  document.addEventListener('pointerdown', (event) => {
    if (
      mobileMenu &&
      !mobileMenu.hidden &&
      !mobileMenu.contains(event.target as Node) &&
      !mobileTrigger?.contains(event.target as Node)
    ) {
      setMobileMenu(false);
    }

    if (!desktopItems.some((item) => item.contains(event.target as Node))) closeDesktopMenus();
    if (!jxlDecoderInfos.some((info) => info.contains(event.target as Node))) closeJxlDecoderMessages();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Tab' && mobileMenu && !mobileMenu.hidden && mobileMedia.matches) {
      const focusable = getMobileMenuFocusable();
      const first = focusable[0];
      const last = focusable.at(-1);
      if (!first || !last) return;

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
      return;
    }

    if (event.key === 'Escape') {
      closeDesktopMenus();
      closeJxlDecoderMessages();
      if (mobileMenu && !mobileMenu.hidden) setMobileMenu(false, true);
    }
  });

  mobileMedia.addEventListener('change', () => setMobileMenu(false));
  showJxlDecoderInfoWhenNeeded();
</script>
