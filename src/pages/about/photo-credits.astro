---
import BaseLayout from '../../layouts/BaseLayout.astro';
import credits from '../../data/photo-credits.json';

const title = 'Photo Credits – JPEG XL';
const description = 'Image credits for jpegxl.info.';
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://jpegxl.info/about/photo-credits.html"
>
  <Fragment slot="head">
    <!-- Local JXL.js fallback renderer for browsers without native JPEG XL support. -->
    <script is:inline src="/serviceworker.min.js"></script>
    <script is:inline src="/resources/jxl.min.js"></script>
    <style is:inline>
      .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
      }
      .card-photo_credit {
        transition: transform 0.3s ease;
      }
      .card-photo_credit:hover {
        transform: translateY(-5px);
      }
      .wrapper-image-photo_credit {
        aspect-ratio: 2 / 1;
        background-color: transparent;
        overflow: hidden;
      }
      .card-photo_credit img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
      }
      .card-photo_credit picture {
        display: block;
        width: 100%;
        height: 100%;
        aspect-ratio: 2 / 1;
        overflow: hidden;
      }
    </style>
  </Fragment>

  <section id="main-content" class="section-hero hero-fullspan-graphic gradient-bottom">
    <div class="container-content-vflex centered">
      <div class="wrapper-text color-gradient">
        <h1 class="display-xl-bold fill-gradient">Photo Credits</h1>
      </div>
      <div class="wrapper-text width-small">
        <h2 class="text-l-medium large">
          Our thanks to the photographers whose beautiful open-source images help create a
          compelling showcase for JPEG&nbsp;XL.
        </h2>
      </div>
    </div>
    <div class="container-wave-animated">
      <div class="wrapper-content-wave centered align-middle height-cropped-width-full">
        <img
          src="/images/Ripple-Line2x-50.0s-2560px-371px.svg"
          loading="lazy"
          alt=""
          class="image-wave-2560"
        /><img
          src="/images/Ripple-Line2x-50.0s-1440px-300px.svg"
          loading="lazy"
          alt=""
          class="image-wave-1440"
        />
      </div>
    </div>
  </section>
  <section class="section-content-wrapper height-100 centered padding-top_bottom">
    <main class="container-content-vflex width-1440">
      <div class="container-content-hflex fullspan">
        <div class="code_embed-photo_credits w-embed">
          <div id="gallery" class="gallery">
            {
              credits.map(({ images: image }) => {
                const imgPath = `/about/OpenSourceImages/${image.file_name}`;
                return (
                  <div class="card-photo_credit">
                    <div class="wrapper-image-photo_credit">
                      <picture>
                        <source srcset={`${imgPath}.jxl`} type="image/jxl" />
                        <img src={`${imgPath}.webp`} alt={image.image_name} loading="lazy" />
                      </picture>
                    </div>
                    <div class="container-card-text">
                      <h3 class="text-photo_credit-image_title">{image.image_name}</h3>
                      <div class="wrapper-text-horizontal">
                        <div class="wrapper-text-hug">
                          <div class="text-all-caps-micro-medium-white">Photographer:</div>
                        </div>
                        <div class="wrapper-text-hug">
                          <p class="text-photo_credit-link">
                            {image.photographer_name ? (
                              image.photographer_portfolio ? (
                                <a
                                  href={image.photographer_portfolio}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                >
                                  {image.photographer_name}
                                </a>
                              ) : (
                                image.photographer_name
                              )
                            ) : (
                              'N/A'
                            )}
                          </p>
                        </div>
                      </div>
                      <div class="wrapper-text-horizontal">
                        <div class="wrapper-text-hug">
                          <div class="text-all-caps-micro-medium-white">Site:</div>
                        </div>
                        <div class="wrapper-text-hug">
                          <p class="text-photo_credit-link">
                            {image.site_name ? (
                              image.image_url ? (
                                <a href={image.image_url} target="_blank" rel="noopener noreferrer">
                                  {image.site_name}
                                </a>
                              ) : (
                                image.site_name
                              )
                            ) : (
                              'N/A'
                            )}
                          </p>
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
    </main>
  </section>
</BaseLayout>
