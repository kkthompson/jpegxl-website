---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/art.css';

const title = "Early JXL Art – JPEG XL";
const description = "JXL Art by Jon Sneyers, created in 2021.";
const canonical = "https://jpegxl.info/art/2021-04_jon.html";
---

<BaseLayout title={title} description={description} canonical={canonical} usesJxlWasmFallback>
  <Fragment slot="head">
    <!-- Local JXL.js fallback renderer for browsers without native JPEG XL support. -->
    <script is:inline src="/serviceworker.min.js?v=1.0.3-art-data"></script>
    <script is:inline src="/resources/jxl.min.js?v=1.0.3-art-data"></script>
  </Fragment>

  <section id="main-content" class="section-hero hero-fullspan-graphic gradient-bottom">
        <div class="container-content-vflex width-page-max centered">
          <div class="wrapper-text color-gradient">
            <h1 class="display-xl-bold fill-gradient">Early JXL art</h1>
          </div>
          <div class="wrapper-text width-small">
            <h2 class="text-l-medium large">by Jon Sneyers, March–April 2021</h2>
          </div>
        </div>
        <div class="container-wave-animated">
          <div class="wrapper-content-wave centered align-middle height-cropped-width-full"><img src="/images/Ripple-Line2x-50.0s-2560px-371px.svg" loading="lazy" alt="" class="image-wave-2560"><img src="/images/Ripple-Line2x-50.0s-1440px-300px.svg" loading="lazy" alt="" class="image-wave-1440"></div>
        </div>
      </section>
      <div class="section-content-wrapper height-100 centered padding-top_bottom">
        <main class="container-content-vflex width-page-max centered">
          <div class="container-content-vflex centered">
            <div class="wrapper-content centered">
              <div class="art-body">
      <a href="/art/" class="art-back">← Back to JXL Art Gallery</a>

      <h3>JXL logo</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 117 bytes</p>
      <img src="data:image/jxl;base64,/wo6HwGRCAYBAKQBC4ALbNQxslZLlFdAkOAPoAehB5BJcYD1Lo0WYXbZB4vCxGjuQc6x/4UgLq5cjpgHPfUXsGDCgv45dgEZBArgt1YI436HAHKD5uNY+OGH8BV0jPMRJGl0oiUXUAHBDV4eWQQw6vhLEg4A" alt="JXL logo">

      <h3>Xorpinski</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 42 bytes</p>
      <img src="data:image/jxl;base64,/wr6H0GRCAYBAHgASzhE3O09oHZZRin0098CMfEAAMigkEJw/wMkCQdI" alt="Xorpinski">

      <h3>The Smoke Machine</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 48 bytes</p>
      <img src="data:image/jxl;base64,/wr6H1FQTEiAQQAAiABLOEPGhtP8gYpUO2iq4J5HAhc9Hxje88YJ24r8Ax5eSBIG" alt="The Smoke Machine">

      <h3>Electric Blues and Reds</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 47 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAIwASzhBtjnLH4o3ax3On+Kj4rj30nwD4LgpFl0AfVhRDmRDkjA=" alt="Electric Blues and Reds">

      <h3>A Perfectly Normal Cave Wall In Hell</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 54 bytes</p>
      <img src="data:image/jxl;base64,/wr6H0GRCAYBAKgASzgkunnw1bRqXacVHHoCmRJgN8GhZ/HBEgiZ3yO8R1QEyxHzYUGScAAA" alt="A Perfectly Normal Cave Wall In Hell">

      <h3>Minor Misalignment</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 46 bytes</p>
      <img src="data:image/jxl;base64,/wraHwGRCAYBAIgASzhB5q0ePFJb2mGMo5jD+7OH9+d+fQNUUJAgoJBCknAAFw==" alt="Minor Misalignment">

      <h3>Sierpinski Archipelago</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 42 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAHgASzhBNneTVowr338Ce+mzof7I3oNsIUP9of4AScIA" alt="Sierpinski Archipelago">

      <h3>Untitled #28</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 43 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAHwASzhD5jb9A6rWn6bUAQeAxX00F+ZgV9gFaXhYkCQcAA==" alt="Untitled #28">

      <h3>Maze</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 42 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAHgASzhBPO24nEjp28EysiBvgfOH8weMrArwSTh/JAkD" alt="Maze">

      <h3>Burning the Queen's Ice and Fire</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 44 bytes</p>
      <img src="data:image/jxl;base64,/wr6H3FATAgGAQB8AEs4QrY5ywN9fl4PdFEOlKGMZbAfvwIhA64fIEk4wAk=" alt="Burning the Queen's Ice and Fire">

      <h3>Synthwave meets Acoustic</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 39 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAGwASzhBtrm8wRs7UVegOGaJ4slHIpeQCeePJGEA" alt="Synthwave meets Acoustic">

      <h3>The Abstract Hills of Super-Jixel-Land</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 59 bytes</p>
      <img src="data:image/jxl;base64,/wr6H7FQTEiAQQAAtABLOEN0w6yr4P2YWOQP5PLQm4Hnnxr3w/LUHyAggsT3iK1E2XCACRQrygZJwgA=" alt="The Abstract Hills of Super-Jixel-Land">

      <h3>The Queen's Fractal</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 21 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBACQAS4oLFgATIAkn" alt="The Queen's Fractal">

      <h3>Coral Reef</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 66 bytes</p>
      <img src="data:image/jxl;base64,/wr6GLFATAhmv+gXASyAEQC8AEs4Qjwt5k9UG5S8OCysfHJ+RxUKwV0JLEQcSIzbcFgQvYPoIRaWjIWoI2xIEg4A" alt="Coral Reef">

      <h3>Fast-forward or Rewind? A Warholian Political Compass</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 101 bytes</p>
      <img src="data:image/jxl;base64,/wr6X5GwEBMIBgEA+AAAAEAABEAABEAABEAABEAAC0RIQEHJjdExOEgM+xdCCljm14PCfpf7rLiGZe33j4GBM+BZ2fNSBJ6yw2mciz759lqxku5qGmVAciQJBwADAwMDAwMDAwM=" alt="Fast-forward or Rewind? A Warholian Political Compass">

      <h3>Inside the Flying Spaghetti Monster</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 48 bytes</p>
      <img src="data:image/jxl;base64,/wr6H0GRCAYBAJAASzglcne/WQlSGiGB45+Fd7v+/qjdR/iIw8AQD0WoFW2QJBwA" alt="Inside the Flying Spaghetti Monster">

      <h3>Unusually Cloudy Desert Sunset, Part 1</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 79 bytes</p>
      <img src="data:image/jxl;base64,/wr6F9NATAgmAP0jgAUwAgDwAEs4Ijp3nmrJz1LyQwg0i74M3nhg1CzrimbRawsWEGYNholRckCz6JtVL0aI05gFhgX3wINQBZ8FScIBAA==" alt="Unusually Cloudy Desert Sunset, Part 1">

      <h3>Unusually Cloudy Desert Sunset, Part 2: Aliens' Earth Simulator Revealed</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 73 bytes</p>
      <img src="data:image/jxl;base64,/wr6H9FATAgGAQDwAEs4Ijp3nmrJz1LyQwg0i74M3nhg1CzrimbRawsWEGYNholRckCz6JtVL0aI05gFhgX3wINQBZ8FScIBAA==" alt="Unusually Cloudy Desert Sunset, Part 2">

      <h3>Cupid's Factory</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 39 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAGwASzhCtjlvwCvy9NvFPsJhYfCVLD2mQW1IEg4A" alt="Cupid's Factory">

      <h3>Alien Message</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 32 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAFAASzhBvO15IutBdUj+EWONJGEBgAA=" alt="Alien Message">

      <h3>Self-assembling Alien Art</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 49 bytes</p>
      <img src="data:image/jxl;base64,/wr6H1FQTAgGAQCQAEs4JJp3vWxBBeeRkvKCFAUXPRs03vN6A0JvPlh24IMeScIBAA==" alt="Self-assembling Alien Art">

      <h3>Alien Art #2</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 30 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAEgASzhC5i390BNw2nk1MCxIEg4A" alt="Alien Art #2">

      <h3>The Glitchy Dunes of Cyberia</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 37 bytes</p>
      <img src="data:image/jxl;base64,/wr6H0GRCAYBAGQASzhE3C1PyMeqYMn/kX4F8TjiQDGBJOEAAA==" alt="The Glitchy Dunes of Cyberia">

      <h3>Alien Farmland</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 36 bytes</p>
      <img src="data:image/jxl;base64,/wr6H7FATAgGAQBcAEs4QrztoTB2LKCxxwE8epRBK0gSDnAC" alt="Alien Farmland">

      <h3>Alien Architecture</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 52 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAKAASzgiOnfKLyl1NObT+JCRR2oVLCCAa5TIMEBkkCxIIgMHgP2IJOEAAA==" alt="Alien Architecture">

      <h3>Alien Bushfires</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 45 bytes</p>
      <img src="data:image/jxl;base64,/wr6H1FQTAgGAQCAAEs4RLY57QHEIzXf+UFbWOLjDgmcf1Tg/OOtMQZJwgFc" alt="Alien Bushfires">

      <h3>Stairway to Heaven</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 33 bytes</p>
      <img src="data:image/jxl;base64,/wr6HwGRCAYBAFQASzhC3O09qH6PCzxI9BB2wQyShAMA" alt="Stairway to Heaven">

      <h3>Tropical Island Sunset</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 116 bytes</p>
      <img src="data:image/jxl;base64,/wr6GOjgaCgmCGa/6BcBPIARAFwBAABAAAQAC4CjbVuVYsvIULAKAFEIv2JAFLEYRfEOYRxhfoAIqQEkn3W4b+piqIveY/kkD/3RLwdjfIAzC3y7o1EcCMmEF3p0TTmhiefnYhxhi+cHWiQzAGkgSTgAAwM=" alt="Tropical Island Sunset">

      <h3>Tropical Island Sunset with JXL logo overlay</h3>
      <p class="art-caption">2021, Jon Sneyers, image/jxl, 218 bytes</p>
      <img src="data:image/jxl;base64,/wraHNTQIGACCJitkOMAHsBAAAB8AQAAQAAEAAuAo21bLaPKyBwPmAAmM/03iRCZjVBUzAilhVqNiIdCcBpMEbiPPg8So43fsXQxjmKEXqbFg0GLk7/d/PkRitc4BCtg8Xlt9FQmeAITz2vFOPuMz4+VMCZYSkCScAAAAwMImK2Q4wAewESiAAAcAQAAQAAEAAuAi2UrKor1RkxDgFBgxeZDMX4rMCb0q/qgOlIYoHnwNz+nVsB/CywPlidcVj7p3xhjtIhBoufAwQ/Swyxj2UWAo4IEKUkYAwM=" alt="Tropical Island Sunset with JXL logo overlay">
              </div>
            </div>
          </div>
        </main>
      </div>
</BaseLayout>
