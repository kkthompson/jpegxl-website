---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/art.css';

const title = "JXL Art (HDR) – JPEG XL";
const description = "HDR JXL art with links to source. Separate page to avoid SDR/HDR mix.";
const canonical = "https://jpegxl.info/art/hdr.html";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <!-- Local JXL.js fallback renderer for browsers without native JPEG XL support. -->
    <script is:inline src="/resources/jxl-mark-embedded.js"></script>
    <script is:inline src="/serviceworker.min.js"></script>
    <script is:inline src="/resources/jxl.min.js"></script>
  </Fragment>

  <section id="main-content" class="section-hero hero-fullspan-graphic gradient-bottom">
        <div class="container-content-vflex width-page-max centered">
          <div class="wrapper-text color-gradient">
            <h1 class="display-xl-bold fill-gradient">JXL Art (HDR)</h1>
          </div>
          <div class="wrapper-text width-small">
            <h2 class="text-l-medium large">HDR pieces from the <a href="https://jxl-art.lucaversari.it/">JXL Art</a> tool, on a separate page so SDR and HDR are not mixed.</h2>
          </div>
        </div>
        <div class="container-wave-animated">
          <div class="wrapper-content-wave centered align-middle height-cropped-width-full"><img src="/images/Ripple-Line2x-50.0s-2560px-371px.svg" loading="lazy" alt="" class="image-wave-2560"><img src="/images/Ripple-Line2x-50.0s-1440px-300px.svg" loading="lazy" alt="" class="image-wave-1440"></div>
        </div>
      </section>
      <div class="section-content-wrapper height-100 centered padding-top_bottom">
        <main class="container-content-vflex width-page-max centered">
          <div class="container-content-vflex centered">
            <div class="wrapper-content centered">
              <div class="art-body">
      <a href="/art/" class="art-back">← Back to JXL Art Gallery</a><br>
      <a href="/art/big_gallery.html" class="art-back">← Back to JXL art (SDR)</a>

      <h3>Chroma and luma (Rec2100 PQ)</h3>
      <p class="art-caption">2024, Jon Sneyers, image/jxl, 55 bytes
      <span class="art-source">
      <a href="https://jxl-art.lucaversari.it/?zcode=i4h04gpKTTYyNDBQCAjk4spMU0hWsFMw4FJQgDINgUwwpxIqDgK6Cn4KuiZwTnBqiYKRgYk5TGkFitJwBVSVukClFhALwnX9woFqdeGW%2BAFFEAIQ3aYIS8OhxoIMyklNLgHKAQA%3D" target="_blank" rel="noopener noreferrer">(source)</a>
      </span></p>
      <img src="data:image/jxl;base64,/wr6HxEAQh494nAAAAAACAiDAACEAAAwAFAAUEo4ROatHuCR2tIOYxwT6ob3PzLA/x+ZMECCAQ==" alt="Chroma and luma (Rec2100 PQ)">

      <h3>freshly baked tray of neoncookieli</h3>
