---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'JXL Art Gallery – JPEG XL';
const description =
  'Procedural images encoded as tiny JPEG XL files – often just a few bytes long. Gallery and browser support test.';
const canonical = 'https://jpegxl.info/art/';
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <!-- JPEG XL polyfill: decodes JXL→PNG via WebAssembly on browsers without
         native support, and auto-skips where JXL is supported natively.
         https://github.com/hjanuschka/jxl-rs-polyfill
         TODO(revert-candidate): does NOT preserve ICC color profiles (decodes
         to untagged 8-bit RGBA). Remove this <script> if it proves problematic. -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/jxl-rs-polyfill/dist/auto.js"></script>
    <style is:inline>
      .art-landing {
        width: 100%;
      }

      .art-section {
        width: 100%;
        padding: clamp(4rem, 8vw, 7rem) 1.5rem;
      }

      .art-section.flush-top {
        padding-top: clamp(2.5rem, 6vw, 5rem);
      }

      .art-container {
        width: 100%;
        max-width: 1120px;
        margin: 0 auto;
      }

      .art-eyebrow {
        color: #1ae5e0;
        font-family: Barlow, sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        margin: 0 0 0.75rem;
        text-transform: uppercase;
      }

      .art-heading {
        color: #fff;
        font-family: Barlow, sans-serif;
        font-size: clamp(2rem, 5vw, 4.5rem);
        font-weight: 600;
        letter-spacing: -0.045em;
        line-height: 0.98;
        margin: 0;
      }

      .art-section-heading {
        color: #fff;
        font-family: Barlow, sans-serif;
        font-size: clamp(1.9rem, 3vw, 3rem);
        font-weight: 600;
        letter-spacing: -0.035em;
        line-height: 1.05;
        margin: 0;
      }

      .art-lede,
      .art-copy,
      .art-feature p,
      .art-callout p {
        color: rgba(255, 255, 255, 0.72);
        font-family: Barlow, sans-serif;
        font-size: 1.08rem;
        font-weight: 400;
        line-height: 1.55;
        margin: 0;
      }

      .art-lede {
        max-width: 42rem;
        margin: 1.5rem auto 0;
        text-align: center;
      }

      .art-actions,
      .art-cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
        margin-top: 2rem;
      }

      .art-button {
        align-items: center;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        color: #fff;
        display: inline-flex;
        font-family: Barlow, sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.75rem 1.25rem;
        text-decoration: none;
        transition: background 0.16s ease, border-color 0.16s ease, transform 0.16s ease;
      }

      .art-button:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.22);
        transform: translateY(-1px);
      }

      .art-button.primary {
        background: #1ba3a0;
        border-color: rgba(255, 255, 255, 0.2);
      }

      .art-hero {
        text-align: center;
      }

      .art-hero.section-hero.hero-fullspan-graphic.gradient-bottom {
        padding-bottom: clamp(1.5rem, 4vw, 3rem);
      }

      .art-hero .container-wave-animated {
        align-self: stretch;
        margin-top: clamp(1.5rem, 4vw, 2.5rem);
        width: 100%;
      }

      .art-hero .art-actions {
        margin-top: clamp(1.25rem, 3vw, 2rem);
      }

      .art-hero-actions {
        width: 100%;
      }

      .art-feature h3,
      .art-callout h3 {
        color: #fff;
        font-family: Barlow, sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 0 0 0.5rem;
      }

      .art-feature-grid,
      .art-about-grid {
        display: grid;
        gap: clamp(0.85rem, 2vw, 1.15rem);
        grid-template-columns: repeat(auto-fit, minmax(min(19rem, 100%), 1fr));
        margin-top: 2rem;
      }

      .art-feature,
      .art-callout {
        background: rgba(24, 25, 27, 0.68);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 1.5rem;
      }

      .art-feature img {
        background: rgba(255, 255, 255, 0.04);
        border-radius: 18px;
        display: block;
        height: 10rem;
        margin-bottom: 1rem;
        object-fit: contain;
        width: 100%;
      }

      .art-about {
        max-width: 70rem;
      }

      .art-about .art-copy + .art-copy {
        margin-top: 1rem;
      }

      .art-link {
        color: #1ae5e0;
        text-decoration: none;
      }

      .art-link:hover {
        text-decoration: underline;
      }

      .art-body {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1rem;
      }

      .art-body h2 {
        color: #1ae5e0;
        font-family: Barlow, sans-serif;
        font-size: 1.6rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 2rem 0 0.75rem;
      }

      .art-body h3 {
        color: rgba(255, 255, 255, 0.96);
        font-family: Barlow, sans-serif;
        font-size: 1.18rem;
        font-weight: 600;
        margin: 1.5rem 0 0.25rem;
      }

      .art-body p,
      .art-body .context {
        color: rgba(255, 255, 255, 0.78);
        font-family: Barlow, sans-serif;
        line-height: 1.6;
        margin: 0.75rem 0;
      }

      .art-body a {
        color: #1ae5e0;
        text-decoration: none;
      }

      .art-body a:hover {
        text-decoration: underline;
      }

      .art-body img {
        display: block;
        height: auto;
        margin: 0.75rem 0 1.25rem;
        max-height: 100vh;
        max-width: 100%;
        object-fit: contain;
        width: auto;
      }

      .art-body .art-caption {
        color: rgba(255, 255, 255, 0.58);
        font-size: 0.9em;
        margin-bottom: 1rem;
      }

      .art-jxl-notice {
        background: rgba(26, 229, 224, 0.08);
        border: 1px solid rgba(26, 229, 224, 0.25);
        border-radius: 12px;
        color: rgba(255, 255, 255, 0.82);
        font-size: 1rem;
        margin: 0 0 1.5rem;
        padding: 0.85rem 1.1rem;
        text-align: center;
        text-wrap: balance;
      }

      .art-jxl-notice[hidden] {
        display: none;
      }

      .art-body code {
        background: rgba(26, 229, 224, 0.15);
        border-radius: 3px;
        font-size: 0.9em;
        padding: 0.1em 0.4em;
