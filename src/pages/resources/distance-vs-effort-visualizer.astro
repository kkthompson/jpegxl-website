---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/distance-vs-effort.css';

const title = 'Distance vs Effort Visualizer – JPEG XL';
const description = 'Compare codecs by perceptual distance and encoding effort.';
---
<BaseLayout title={title} description={description} canonical="https://jpegxl.info/resources/distance-vs-effort-visualizer.html" usesJxlWasmFallback>
  <Fragment slot="head">
    <!-- JXL.js fallback renderer for browsers without native JPEG XL support.
         The service worker supplies COOP/COEP headers when the host does not. -->
    <script is:inline src="/serviceworker.min.js"></script>
    <script is:inline src="/resources/jxl.min.js"></script>
  </Fragment>
<section id="main-content" class="section-hero hero-fullspan-graphic gradient-bottom">
      <div class="container-content-vflex width-page-max centered">
        <div class="wrapper-text color-gradient _40em">
          <h1 class="display-xl-bold fill-gradient">Distance vs Effort Visualizer</h1>
        </div>
        <div class="wrapper-text width-small">
          <h2 class="text-l-medium large">Interactively visualize how varying the visual distance target (quality) and
            encoder effort affect image appearance with the official JPEG&nbsp;XL reference encoder.</h2>
        </div>
      </div>
      <div class="container-wave-animated">
        <div class="wrapper-content-wave centered align-middle height-cropped-width-full"><img
            src="/images/Ripple-Line2x-50.0s-2560px-371px.svg" loading="lazy" alt="" class="image-wave-2560"><img
            src="/images/Ripple-Line2x-50.0s-1440px-300px.svg" loading="lazy" alt="" class="image-wave-1440"></div>
      </div>
    </section>
    <div class="section-content-wrapper height-100 centered padding-top_bottom">
      <main class="container-content-vflex width-page-max centered">
        <div class="container-content-vflex centered">
          <div class="wrapper-content centered">
            <div class="code-distance_vs_effort w-embed">
              <div class="container">
                <select id="image-dropdown"></select>
                <div class="image-slider-container">
                  <div id="image-viewport" class="image-pan-viewport">
                    <img id="image" src="" alt="Image" class="no-smoothing" draggable="false" width="896" height="448">
                  </div>
                  <div id="vertical-slider-container" class="effort-slider-container">
                    <div class="vertical-control">
                      <label for="effort-slider" class="effort-label">Effort:</label>
                      <div class="vertical-slider-row">
                        <input type="range" orient="vertical" id="effort-slider" min="0" value="0" step="1">
                        <div class="effort-slider-labels" id="effort-slider-labels"></div>
                      </div>
                    </div>
                    <div class="vertical-control zoom-slider-container">
                      <label for="zoom-slider" class="zoom-label">Zoom: <span id="zoom-value">1x</span></label>
                      <div class="vertical-slider-row">
                        <input type="range" orient="vertical" id="zoom-slider" min="1" max="5" value="1" step="0.1" aria-label="Image zoom">
                      </div>
                    </div>
                  </div>
                </div>
                <br>
                <div class="bottom-container">
                  <div class="slider-container">
                    <label for="slider" class="distance-label">Distance:</label>
                    <input type="range" id="slider" min="0" value="0" step="1">
                    <div class="slider-labels" id="slider-labels"></div>
                  </div>
                  <div class="info">
                    <p><span class="label">Size:</span> <span id="size"></span> bytes</p>
                    <p><span class="label">BPP:</span> <span id="bpp"></span></p>
                    <p><span class="label">SSIMU2:</span> <span id="ssim"></span></p>
                    <p><span class="label">Encoding Time:</span> <span id="compression-time"></span> s</p>
                  </div>
                </div>
                <section class="tradeoff-chart" aria-label="Compression trade-offs chart">
                  <div class="tradeoff-chart-header">
                    <div>
                      <p class="tradeoff-chart-kicker">Compression trade-offs</p>
                      <p class="tradeoff-chart-intro">Each line shows what a higher encoder effort buys at the same visual distance.</p>
                    </div>
                    <div class="tradeoff-chart-controls" role="group" aria-label="Chart metric">
                      <button type="button" class="tradeoff-chart-toggle is-selected" data-chart-metric="size" aria-pressed="true">File size</button>
                      <button type="button" class="tradeoff-chart-toggle" data-chart-metric="time" aria-pressed="false">Encoding time</button>
                    </div>
                  </div>
                  <svg id="tradeoff-chart-svg" class="tradeoff-chart-svg" viewBox="0 0 896 416" role="img" aria-label="Compression trade-offs chart" aria-describedby="tradeoff-chart-description"></svg>
                  <p id="tradeoff-chart-description" class="visually-hidden"></p>
                  <div id="tradeoff-chart-legend" class="tradeoff-chart-legend" aria-label="Effort line legend"></div>
                  <p class="tradeoff-chart-caption">The outlined line and point match your current effort. The vertical guide compares every effort at the selected distance.</p>
                </section>
              </div>
            </div>
          </div>
        </div>
        <div class="spacer-4rem"></div>
        <div class="visualizer-notes">
          <div class="text-small-regular centered"><b>Distance</b> quantifies visual distortion using the psychovisually
              robust Butteraugli metric, where zero represents mathematically lossless compression.
          </div>
          <p></p>
          <div class="text-small-regular centered"><b>Effort</b> controls the amount of computing power (CPU and memory)
            used to optimize compression efficiency while maintaining the target distance.
          </div>
          <p></p>
          <div class="text-small-regular centered"><b>Encoding Time:</b> Images were compressed using libjxl 0.12 on a
            12-Core (8 Performance & 4 Efficiency), 96GB, M2 Max MacBook Pro on July 11, 2026.</div>
        </div>
        <div class="spacer-4rem"></div>
      </main>
    </div>
    <div class="spacer-4rem"></div>
    <div class="spacer-4rem"></div>
<script is:inline src="/resources/DistanceVsEffort.js"></script>
</BaseLayout>
