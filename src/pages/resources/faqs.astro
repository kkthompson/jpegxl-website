---
import { getCollection } from 'astro:content';
import { Marked, Renderer, marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryTabs from '../../components/CategoryTabs.astro';
import PageHero from '../../components/PageHero.astro';
import '../../styles/category-tabs.css';

const title = 'FAQs – JPEG XL';
const description = 'Frequently asked questions about the JPEG XL image format.';
const canonical = 'https://jpegxl.info/resources/faqs.html';

const categories = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

type MarkdownToken = ReturnType<typeof marked.lexer>[number];

function escapeHtml(value: string) {
  const characters: Record<string, string> = {
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;',
  };

  return value.replace(/[&<>"']/g, (character) => characters[character]);
}

const faqRenderer = new Renderer();
faqRenderer.code = ({ text, lang, escaped }) => {
  const language = lang?.match(/\S+/)?.[0] ?? '';
  const languageLabel = language ? language.toUpperCase() : 'CODE';
  const languageClass = language ? ` class="language-${escapeHtml(language)}"` : '';
  const code = escaped ? text : escapeHtml(text);

  return `<figure class="faq-code-block" data-language="${escapeHtml(languageLabel)}"><figcaption><span>${escapeHtml(languageLabel)}</span><button type="button" class="faq-copy-button" data-copy-code aria-label="Copy ${escapeHtml(languageLabel)} code">Copy</button></figcaption><pre><code${languageClass}>${code}</code></pre></figure>`;
};

const faqMarked = new Marked({ renderer: faqRenderer });

function trimAnswerTokens(tokens: MarkdownToken[]) {
  let start = 0;
  let end = tokens.length;

  while (start < end && tokens[start].type === 'space') start += 1;
  while (end > start && ['space', 'hr'].includes(tokens[end - 1].type)) end -= 1;

  return tokens.slice(start, end);
}

function getFaqItems(markdown: string) {
  const tokens = marked.lexer(markdown);
  const items: { question: string; answerHtml: string; schemaHtml: string }[] = [];
  let question: string | null = null;
  let answerTokens: MarkdownToken[] = [];

  function pushCurrentItem() {
    if (!question) return;
    const trimmedTokens = trimAnswerTokens(answerTokens);
    const answerHtml = faqMarked.parser(trimmedTokens);
    const schemaHtml = marked.parser(trimmedTokens);
    if (answerHtml.trim()) items.push({ question, answerHtml, schemaHtml });
  }

  for (const token of tokens) {
    if (token.type === 'heading' && token.depth === 3) {
      pushCurrentItem();
      question = token.text;
      answerTokens = [];
      continue;
    }

    if (question) answerTokens.push(token);
  }

  pushCurrentItem();
  return items;
}

const rendered = categories.map((entry) => ({
  entry,
  items: getFaqItems(entry.body ?? ''),
}));

const updatedCategories = rendered.filter(({ entry }) => entry.data.lastUpdated);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: rendered.flatMap(({ items }) =>
    items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.schemaHtml,
      },
    })),
  ),
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <style is:inline>
      html {
        overflow-y: scroll;
        scrollbar-gutter: stable;
      }
      .wrapper {
        width: 100%;
      }
      .resource-tab-layout {
        display: grid;
        grid-template-columns: minmax(11rem, 13rem) minmax(0, 1fr);
        gap: clamp(1.5rem, 4vw, 3.5rem);
        align-items: start;
        width: 100%;
      }
      .resource-tab-layout > :last-child,
      .code-faqs {
        width: 100%;
        min-width: 0;
      }
      .resource-tab-rail {
        position: sticky;
        top: 1.5rem;
        padding: 0.75rem;
        border: 1px solid color-mix(in srgb, var(--brand--teal-bright--500) 24%, var(--line-divider));
        border-radius: var(--radius--small);
        background: color-mix(in srgb, var(--page-black) 65%, transparent);
      }
      .tab-content {
        box-sizing: border-box;
        padding: 20px;
        background: #1e1e1e;
        border-radius: 10px;
        margin-top: 20px;
        width: 100%;
      }
      .tab-content[hidden] {
        display: none;
      }
      .faq-item {
        margin: 0;
      }
      .faq-item + .faq-item {
        border-top: 1px solid var(--line-divider);
      }
      .text-question-faq {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin: 0;
        padding: 1.25em 0 0.75em;
        cursor: pointer;
        list-style: none;
      }
      .text-question-faq > :first-child {
        min-width: 0;
        flex: 1 1 auto;
      }
      .text-question-faq::-webkit-details-marker {
        display: none;
      }
      .text-answer-faq {
        font-size: 1.125rem;
        font-weight: 300;
        margin-top: 0;
        margin-bottom: 1.5em;
        color: var(--text--color--text-white);
        text-wrap: pretty;
        padding-bottom: 1.5em;
      }
      .text-answer-faq li {
        font-family: var(--font--font-family--barlow);
        font-size: clamp(0.9375rem, calc(0.872rem + 0.282vw), 1.125rem);
        font-weight: 300;
        color: inherit;
        letter-spacing: -0.01em;
        line-height: 1.45em;
      }
      .text-answer-faq :not(pre) > code {
        border: 1px solid color-mix(in srgb, var(--brand--teal-bright--P3--500) 22%, transparent);
        border-radius: 0.35rem;
        background: color-mix(in srgb, var(--brand--teal-bright--P3--500) 10%, transparent);
        color: var(--text--color--text-white);
        font-family: var(--font--font-family--monospace);
        font-size: 0.88em;
        font-weight: 500;
        padding: 0.08em 0.32em;
        white-space: nowrap;
      }
      .faq-code-block {
        overflow: hidden;
        margin: 1rem 0 1.25rem;
        border: 1px solid color-mix(in srgb, var(--brand--teal-bright--P3--500) 22%, var(--line-divider));
        border-radius: 8px;
        background:
          linear-gradient(
            180deg,
            color-mix(in srgb, var(--brand--teal-bright--P3--500) 12%, #24262a) 0%,
            #18191b 56%
          );
        box-shadow: inset 0 1px 0 color-mix(in srgb, var(--white) 8%, transparent);
        text-align: left;
      }
      .faq-code-block figcaption {
        border-bottom: 1px solid color-mix(in srgb, var(--white) 9%, transparent);
        color: color-mix(in srgb, var(--brand--teal-bright--P3--500) 80%, var(--white));
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        font-family: var(--font--font-family--monospace);
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        line-height: 1;
        padding: 0.7rem 1rem 0.62rem;
      }
      .faq-copy-button {
        appearance: none;
        border: 1px solid color-mix(in srgb, var(--brand--teal-bright--P3--500) 35%, transparent);
        border-radius: 999px;
        background: color-mix(in srgb, var(--white) 7%, transparent);
        color: var(--text--color--text-white);
        cursor: pointer;
        font: inherit;
        font-size: 0.6875rem;
        letter-spacing: 0.08em;
        line-height: 1;
        padding: 0.4rem 0.65rem;
        transition:
          background-color 0.2s ease,
          border-color 0.2s ease,
          color 0.2s ease,
          transform 0.2s ease;
      }
      .faq-copy-button:hover,
      .faq-copy-button:focus-visible {
        border-color: color-mix(in srgb, var(--brand--teal-bright--P3--500) 72%, transparent);
        background: color-mix(in srgb, var(--brand--teal-bright--P3--500) 18%, transparent);
        color: var(--white);
      }
      .faq-copy-button:focus-visible {
        outline: 2px solid var(--brand--teal-bright--P3--500);
        outline-offset: 2px;
      }
      .faq-copy-button:active {
        transform: translateY(1px);
      }
      .faq-copy-button.is-copied {
        border-color: color-mix(in srgb, var(--brand--teal-bright--P3--500) 85%, transparent);
        background: color-mix(in srgb, var(--brand--teal-bright--P3--500) 24%, transparent);
        color: var(--white);
      }
      .faq-code-block pre {
        overflow-x: auto;
        margin: 0;
        padding: 1rem;
        -webkit-overflow-scrolling: touch;
      }
      .faq-code-block code {
        display: block;
        color: var(--text--color--text-white);
        font-family: var(--font--font-family--monospace);
        font-size: clamp(0.8125rem, calc(0.77rem + 0.18vw), 0.9375rem);
        font-weight: 400;
        line-height: 1.65;
        tab-size: 2;
        white-space: pre;
      }
      .text-answer-faq :first-child {
        margin-top: 0;
      }
      .text-answer-faq :last-child {
        margin-bottom: 0;
      }
      .disclosure-icon {
        width: 20px;
        height: 20px;
        background-color: var(--brand--blue--P3--500);
        border-radius: 50%;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        flex: 0 0 20px;
        position: relative;
        transition:
          transform 0.3s ease,
          background-color 0.3s ease;
      }
      .disclosure-icon::before,
      .disclosure-icon::after {
        content: '';
        position: absolute;
        background-color: var(--white);
        transition: transform 0.3s ease;
      }
      .disclosure-icon::before {
        width: 2px;
        height: 10px;
      }
      .disclosure-icon::after {
        width: 10px;
        height: 2px;
      }
      .faq-item[open] .disclosure-icon {
        transform: rotate(180deg);
        background-color: var(--brand--teal-bright--P3--500);
      }
      .faq-item[open] .disclosure-icon::before {
        transform: rotate(90deg);
      }
      .code-faqs hr {
        border: 0;
        height: 1px;
        background: var(--line-divider);
        margin: 20px 0;
      }
      .faq-updated-footer {
        margin: 1rem 0 0;
        color: color-mix(in srgb, var(--text--color--text-white) 70%, transparent);
        font-size: 0.875rem;
        font-weight: 300;
        line-height: 1.4;
        text-align: center;
      }
      .faq-updated-footer span + span::before {
        content: ' · ';
      }
      @media (max-width: 767px) {
        .resource-tab-layout {
          display: block;
        }
        .resource-tab-rail {
          position: static;
          margin-bottom: 1.25rem;
          padding: 0;
          border: 0;
          background: transparent;
        }
      }
    </style>
  </Fragment>

  <PageHero
    title="FAQs"
    subtitle="This FAQ aims to answer some commonly asked questions about JPEG XL and associated technologies."
  />
  <div class="section-content-wrapper height-100 centered padding-top_bottom">
    <main class="container-content-vflex width-page-max centered">
      <div class="container-content-vflex">
        <div class="wrapper-content centered">
          <div class="code-faqs w-embed">
            <div class="resource-tab-layout">
              <aside class="resource-tab-rail">
                <CategoryTabs
                  ariaLabel="FAQ categories"
                  categories={rendered.map(({ entry }) => ({ label: entry.data.title }))}
                  idPrefix="faq"
                  orientation="vertical"
                />
              </aside>
              <div>
            {
              rendered.map(({ items }, i) => (
                <div
                  id={`faq-panel-${i}`}
                  class="tab-content"
                  role="tabpanel"
                  aria-labelledby={`faq-tab-${i}`}
                  hidden={i !== 0}
                >
                  {items.map((item) => (
                    <details class="faq-item">
                      <summary class="text-question-faq">
                        <span>{item.question}</span>
                        <span class="disclosure-icon" aria-hidden="true"></span>
                      </summary>
                      <div class="text-answer-faq" set:html={item.answerHtml} />
                    </details>
                  ))}
                </div>
              ))
            }
            {
              updatedCategories.length > 0 && (
                <footer class="faq-updated-footer" aria-label="FAQ update dates">
                  <span>Last updated:</span>
                  {updatedCategories.map(({ entry }) => (
                    <span>
                      {entry.data.title}: {entry.data.lastUpdated}
                    </span>
                  ))}
                </footer>
              )
            }
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    import { initCategoryTabs } from '../../scripts/category-tabs';

    const tabsContainer = document.getElementById('faq-tabs')!;
    const select = document.getElementById('faq-select') as HTMLSelectElement;
    const tabContents = document.querySelectorAll<HTMLElement>('.tab-content');
    const copyButtons = document.querySelectorAll<HTMLButtonElement>('[data-copy-code]');

    initCategoryTabs({ tabList: tabsContainer, panels: Array.from(tabContents), select });

    async function copyText(text: string) {
      await navigator.clipboard.writeText(text);
    }

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const code = button.closest('.faq-code-block')?.querySelector('code')?.textContent;
        if (!code) return;

        const defaultLabel = button.dataset.defaultLabel ?? button.textContent ?? 'Copy';
        button.dataset.defaultLabel = defaultLabel;

        try {
          await copyText(code);
          button.textContent = 'Copied';
          button.classList.add('is-copied');
          window.setTimeout(() => {
            button.textContent = defaultLabel;
            button.classList.remove('is-copied');
          }, 1800);
        } catch {
          button.textContent = 'Failed';
          window.setTimeout(() => {
            button.textContent = defaultLabel;
          }, 1800);
        }
      });
    });
  </script>
</BaseLayout>
