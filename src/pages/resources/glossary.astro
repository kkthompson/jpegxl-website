---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import glossaryData from '../../data/glossary.json';

const title = 'Glossary – JPEG XL';
const description = 'Definitions of terms used in the JPEG XL ecosystem.';

// Group terms by subcategory (tab order = first appearance in the JSON),
// alphabetized within each tab. Definitions are trusted HTML from our own data.
const subcategories = [...new Set(glossaryData.map((item) => item.subcategory))];
const termId = (term: string) => term.replace(/\s+/g, '-').toLowerCase();
const grouped = subcategories.map((subcategory) => ({
  subcategory,
  terms: glossaryData
    .filter((item) => item.subcategory === subcategory)
    .sort((a, b) => a.term.localeCompare(b.term)),
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://jpegxl.info/resources/glossary.html"
>
  <Fragment slot="head">
    <style is:inline>
      .w-embed {
        width: 100%;
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .wrapper {
        text-align: center;
        margin: 20px 0;
        width: 100%;
        max-width: 100%;
      }
      .tabs {
        font-size: 16px;
        padding: 0;
        list-style: none;
        background: #494b50;
        display: inline-flex;
        border-radius: 50px;
        box-shadow: 2px 2px 4px #18191b inset;
        position: relative;
        width: fit-content;
        justify-content: center;
      }
      .tabs a {
        text-decoration: none;
        color: #18191b;
        padding: 8px 24px;
        display: inline-block;
        position: relative;
        z-index: 1;
        transition-duration: 0.6s;
      }
      .tabs a.active {
        color: #fff;
      }
      .tabs .selector {
        height: 100%;
        display: inline-block;
        position: absolute;
        left: 0;
        top: 0;
        z-index: 1;
        border-radius: 50px;
        border: 1px solid #18191b;
        box-shadow: 0 0 16px #18191b;
        transition-duration: 0.6s;
        transition-timing-function: cubic-bezier(0.68, -0.55, 0.265, 1.55);
        background: linear-gradient(45deg, #1ae5e0 0%, #0f8a86 100%);
      }
      .glossary-content {
        opacity: 1;
        transition: opacity 0.3s ease-in-out;
        padding: 20px;
        background: #1e1e1e;
        border-radius: 10px;
        margin-top: 20px;
        width: 100%;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
      .glossary-content.fade-out {
        opacity: 0;
      }
      .glossary-term {
        margin-bottom: 20px;
        width: 100%;
      }
      .term {
        font-size: 1.2em;
        font-weight: 500;
        cursor: pointer;
        color: #fff;
      }
      .definition {
        margin-top: 5px;
        padding: 10px;
      }
      .glossary-content a {
        color: #4da6ff;
        text-decoration: none;
      }
      .glossary-content a:hover {
        color: #80bfff;
      }
      .dropdown {
        display: none;
        position: relative;
        width: 100%;
        max-width: 300px;
        margin: 0 auto;
      }
      .dropdown select {
        width: 100%;
        padding: 10px;
        font-size: 16px;
        border: 0;
        border-radius: 50px;
        appearance: none;
        background-color: #494b50;
        color: #fff;
        cursor: pointer;
        text-align: center;
        text-align-last: center;
      }
      .dropdown::after {
        content: '\25BC';
        position: absolute;
        top: 50%;
        right: 15px;
        transform: translateY(-50%);
        pointer-events: none;
        color: #fff;
      }
      @media (max-width: 800px) {
        .tabs {
          display: none;
        }
        .dropdown {
          display: block;
        }
      }
    </style>
  </Fragment>

  <PageHero
    title="Glossary"
    subtitle="Welcome to the JPEG XL Glossary — your go-to guide for key concepts, terms and technology behind the next-generation image standard."
  />
  <div class="section-content-wrapper height-100 centered padding-top_bottom">
    <main class="container-content-vflex width-page-max centered">
      <div class="container-content-vflex centered">
        <div class="wrapper-content centered">
          <div class="w-embed">
            <div class="wrapper">
              <nav class="tabs" id="tab-bar" aria-label="Glossary categories">
                <div class="selector"></div>
                {
                  grouped.map(({ subcategory }, index) => (
                    <a href="#" class={index === 0 ? 'active' : ''} data-index={index}>
                      {subcategory}
                    </a>
                  ))
                }
              </nav>
              <div class="dropdown">
                <label class="sr-only" for="category-dropdown">Glossary category</label>
                <select id="category-dropdown">
                  {
                    grouped.map(({ subcategory }, index) => (
                      <option value={index}>{subcategory}</option>
                    ))
                  }
                </select>
              </div>
            </div>
            <div id="glossary-content" class="glossary-content">
              {
                grouped.map(({ terms }, index) => (
                  <div
                    class="glossary-panel"
                    data-index={index}
                    style={index === 0 ? undefined : 'display: none;'}
                  >
                    {terms.map((item) => (
                      <div class="glossary-term">
                        <details>
                          <summary class="term">
                            <a id={termId(item.term)} href={`#${termId(item.term)}`}>
                              {item.term}
                            </a>
                          </summary>
                          <div class="definition" set:html={item.definition} />
                        </details>
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script>
    const tabs = document.querySelectorAll<HTMLAnchorElement>('.tabs a');
    const selector = document.querySelector<HTMLElement>('.selector')!;
    const dropdown = document.getElementById('category-dropdown') as HTMLSelectElement;
    const content = document.getElementById('glossary-content')!;
    const panels = content.querySelectorAll<HTMLElement>('.glossary-panel');

    function setSelector(elem: HTMLElement) {
      selector.style.width = elem.offsetWidth + 'px';
      selector.style.left = elem.offsetLeft + 'px';
    }

    function switchTab(index: number, fade = true) {
      tabs.forEach((tab, i) => tab.classList.toggle('active', i === index));
      if (tabs[index]) setSelector(tabs[index]);
      dropdown.value = String(index);

      const show = () =>
        panels.forEach((panel, i) => (panel.style.display = i === index ? '' : 'none'));
      if (fade) {
        content.classList.add('fade-out');
        setTimeout(() => {
          show();
          content.classList.remove('fade-out');
        }, 300);
      } else {
        show();
      }
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', (e) => {
        e.preventDefault();
        switchTab(index);
      });
    });

    dropdown.addEventListener('change', () => switchTab(parseInt(dropdown.value)));

    // Clicking a term's link toggles its definition without moving the page.
    content.addEventListener('click', (e) => {
      const anchor = (e.target as HTMLElement).closest('summary.term a');
      if (!anchor) return;
      e.preventDefault();
      const details = anchor.closest('details')!;
      details.open = !details.open;
    });

    // Deep links (#term-id): jump to the right tab, open and scroll to the term.
    function openFromHash() {
      const term = window.location.hash.substring(1);
      if (!term) return;
      const anchor = document.getElementById(term);
      if (!anchor || !content.contains(anchor)) return;
      const panel = anchor.closest<HTMLElement>('.glossary-panel')!;
      switchTab(Number(panel.dataset.index), false);
      const details = anchor.closest('details')!;
      details.open = true;
      anchor.scrollIntoView();
    }

    setSelector(tabs[0]);
    openFromHash();
    window.addEventListener('hashchange', openFromHash);
  </script>
</BaseLayout>
