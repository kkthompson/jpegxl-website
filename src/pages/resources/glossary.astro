---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import glossaryData from '../../data/glossary.json';
import '../../styles/category-tabs.css';

const title = 'Glossary – JPEG XL';
const description = 'Definitions of terms used in the JPEG XL ecosystem.';

// Group terms by subcategory (tab order = first appearance in the JSON),
// alphabetized within each tab. Definitions are trusted HTML from our own data.
const subcategories = [...new Set(glossaryData.map((item) => item.subcategory))];
const termId = (term: string) => term.replace(/\s+/g, '-').toLowerCase();
const grouped = subcategories.map((subcategory) => ({
  subcategory,
  terms: glossaryData
    .filter((item) => item.subcategory === subcategory)
    .sort((a, b) => a.term.localeCompare(b.term)),
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://jpegxl.info/resources/glossary.html"
>
  <Fragment slot="head">
    <style is:inline>
      .w-embed {
        width: 100%;
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .wrapper {
        text-align: center;
        margin: 20px 0;
        width: 100%;
        max-width: 100%;
      }
      .glossary-content {
        opacity: 1;
        transition: opacity 0.3s ease-in-out;
        padding: 20px;
        background: #1e1e1e;
        border-radius: 10px;
        margin-top: 20px;
        width: 100%;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
      .glossary-content.fade-out {
        opacity: 0;
      }
      .glossary-term {
        margin-bottom: 20px;
        width: 100%;
      }
      .term {
        font-size: 1.2em;
        font-weight: 500;
        cursor: pointer;
        color: #fff;
      }
      .definition {
        margin-top: 5px;
        padding: 10px;
      }
      .glossary-content a {
        color: #4da6ff;
        text-decoration: none;
      }
      .glossary-content a:hover {
        color: #80bfff;
      }
      .dropdown {
        display: none;
        position: relative;
        width: 100%;
        max-width: 300px;
        margin: 0 auto;
      }
      .dropdown select {
        width: 100%;
        padding: 10px;
        font-size: 16px;
        border: 0;
        border-radius: 50px;
        appearance: none;
        background-color: #494b50;
        color: #fff;
        cursor: pointer;
        text-align: center;
        text-align-last: center;
      }
      .dropdown::after {
        content: '\25BC';
        position: absolute;
        top: 50%;
        right: 15px;
        transform: translateY(-50%);
        pointer-events: none;
        color: #fff;
      }
      @media (max-width: 800px) {
        .category-tabs {
          display: none;
        }
        .dropdown {
          display: block;
        }
      }
    </style>
  </Fragment>

  <PageHero
    title="Glossary"
    subtitle="Welcome to the JPEG XL Glossary — your go-to guide for key concepts, terms and technology behind the next-generation image standard."
  />
  <div class="section-content-wrapper height-100 centered padding-top_bottom">
    <main class="container-content-vflex width-page-max centered">
      <div class="container-content-vflex centered">
        <div class="wrapper-content centered">
          <div class="w-embed">
            <div class="wrapper">
              <div class="category-tabs" id="tab-bar" role="tablist" aria-label="Glossary categories">
                <div class="selector"></div>
                {
                  grouped.map(({ subcategory }, index) => (
                    <button
                      type="button"
                      id={`glossary-tab-${index}`}
                      role="tab"
                      aria-selected={index === 0 ? 'true' : 'false'}
                      aria-controls={`glossary-panel-${index}`}
                      data-index={index}
                    >
                      {subcategory}
                    </button>
                  ))
                }
              </div>
              <div class="dropdown">
                <label class="sr-only" for="category-dropdown">Glossary category</label>
                <select id="category-dropdown">
                  {
                    grouped.map(({ subcategory }, index) => (
                      <option value={index}>{subcategory}</option>
                    ))
                  }
                </select>
              </div>
            </div>
            <div id="glossary-content" class="glossary-content">
              {
                grouped.map(({ terms }, index) => (
                  <div
                    id={`glossary-panel-${index}`}
                    class="glossary-panel"
                    role="tabpanel"
                    aria-labelledby={`glossary-tab-${index}`}
                    data-index={index}
                    hidden={index !== 0}
                  >
                    {terms.map((item) => (
                      <div class="glossary-term">
                        <details>
                          <summary class="term">
                            <a id={termId(item.term)} href={`#${termId(item.term)}`}>
                              {item.term}
                            </a>
                          </summary>
                          <div class="definition" set:html={item.definition} />
                        </details>
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script>
    import { initCategoryTabs } from '../../scripts/category-tabs';

    const tabList = document.querySelector<HTMLElement>('.category-tabs')!;
    const dropdown = document.getElementById('category-dropdown') as HTMLSelectElement;
    const content = document.getElementById('glossary-content')!;
    const panels = Array.from(content.querySelectorAll<HTMLElement>('.glossary-panel'));
    const categoryTabs = initCategoryTabs({
      tabList,
      panels,
      onChange: ({ index, animate, showPanels }) => {
        dropdown.value = String(index);
        if (!animate) {
          showPanels();
          return;
        }
        content.classList.add('fade-out');
        window.setTimeout(() => {
          showPanels();
          content.classList.remove('fade-out');
        }, 300);
      },
    });

    dropdown.addEventListener('change', () =>
      categoryTabs.activate(parseInt(dropdown.value), { source: 'programmatic' }),
    );

    // Clicking a term's link toggles its definition without moving the page.
    content.addEventListener('click', (e) => {
      const anchor = (e.target as HTMLElement).closest('summary.term a');
      if (!anchor) return;
      e.preventDefault();
      const details = anchor.closest('details')!;
      details.open = !details.open;
    });

    // Deep links (#term-id): jump to the right tab, open and scroll to the term.
    function openFromHash() {
      const term = window.location.hash.substring(1);
      if (!term) return;
      const anchor = document.getElementById(term);
      if (!anchor || !content.contains(anchor)) return;
      const panel = anchor.closest<HTMLElement>('.glossary-panel')!;
      categoryTabs.activate(Number(panel.dataset.index), { animate: false, source: 'programmatic' });
      const details = anchor.closest('details')!;
      details.open = true;
      anchor.scrollIntoView();
    }
    openFromHash();
    window.addEventListener('hashchange', openFromHash);
  </script>
</BaseLayout>
