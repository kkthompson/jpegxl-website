---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryTabs from '../../components/CategoryTabs.astro';
import PageHero from '../../components/PageHero.astro';
import glossaryData from '../../data/glossary.json';
import '../../styles/category-tabs.css';

const title = 'Glossary – JPEG XL';
const description = 'Definitions of terms used in the JPEG XL ecosystem.';

// Group terms by subcategory (tab order = first appearance in the JSON),
// alphabetized within each tab. Definitions are trusted HTML from our own data.
const subcategories = [...new Set(glossaryData.map((item) => item.subcategory))];
const termId = (term: string) => term.replace(/\s+/g, '-').toLowerCase();
const grouped = subcategories.map((subcategory) => ({
  subcategory,
  terms: glossaryData
    .filter((item) => item.subcategory === subcategory)
    .sort((a, b) => a.term.localeCompare(b.term)),
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://jpegxl.info/resources/glossary.html"
>
  <Fragment slot="head">
    <style is:inline>
      .w-embed {
        width: 100%;
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .wrapper {
        width: 100%;
      }
      .resource-tab-layout {
        display: grid;
        grid-template-columns: minmax(11rem, 13rem) minmax(0, 1fr);
        gap: clamp(1.5rem, 4vw, 3.5rem);
        align-items: start;
        width: 100%;
      }
      .resource-tab-rail {
        position: sticky;
        top: 1.5rem;
        padding: 0.75rem;
        border: 1px solid color-mix(in srgb, var(--brand--teal-bright--500) 24%, var(--line-divider));
        border-radius: var(--radius--small);
        background: color-mix(in srgb, var(--page-black) 65%, transparent);
      }
      .glossary-content {
        opacity: 1;
        transition: opacity 0.3s ease-in-out;
        padding: 20px;
        background: var(--surface--elevated);
        border-radius: 10px;
        width: 100%;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
      .glossary-content.fade-out {
        opacity: 0;
      }
      .glossary-term {
        margin: 0;
        width: 100%;
      }
      .glossary-term + .glossary-term {
        border-top: 1px solid var(--line-divider);
      }
      .term {
        margin: 0;
        padding: 1.25em 0 0.75em;
        cursor: pointer;
        color: var(--brand--teal-bright--P3--700);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        list-style: none;
      }
      .term::-webkit-details-marker {
        display: none;
      }
      .definition {
        margin-top: 0;
        margin-bottom: 1.5em;
        padding-bottom: 1.5em;
        color: var(--text--color--text-white);
        font-size: 1.125rem;
        font-weight: 300;
        text-wrap: pretty;
      }
      .definition :first-child {
        margin-top: 0;
      }
      .definition :last-child {
        margin-bottom: 0;
      }
      .glossary-content a {
        color: var(--text--color--link);
        text-decoration: none;
      }
      .glossary-content a:hover {
        color: var(--text--color--link-hover);
      }
      .term a,
      .term a:hover {
        color: inherit;
      }
      .disclosure-icon {
        display: inline-flex;
        width: 20px;
        height: 20px;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background-color: var(--brand--blue--P3--500);
        transition: transform 0.3s ease, background-color 0.3s ease;
      }
      .disclosure-icon::before,
      .disclosure-icon::after {
        position: absolute;
        content: '';
        background-color: var(--white);
        transition: transform 0.3s ease;
      }
      .disclosure-icon::before {
        width: 2px;
        height: 10px;
      }
      .disclosure-icon::after {
        width: 10px;
        height: 2px;
      }
      .glossary-term details[open] .disclosure-icon {
        transform: rotate(180deg);
        background-color: var(--brand--teal-bright--P3--500);
      }
      .glossary-term details[open] .disclosure-icon::before {
        transform: rotate(90deg);
      }
      @media (max-width: 767px) {
        .resource-tab-layout {
          display: block;
        }
        .resource-tab-rail {
          position: static;
          margin-bottom: 1.25rem;
          padding: 0;
          border: 0;
          background: transparent;
        }
      }
    </style>
  </Fragment>

  <PageHero
    title="Glossary"
    subtitle="Welcome to the JPEG XL Glossary, your go-to guide for key concepts, terms and technology behind the next-generation image standard."
  />
  <div class="section-content-wrapper height-100 centered padding-top_bottom">
    <main class="container-content-vflex width-page-max centered">
      <div class="container-content-vflex centered">
        <div class="wrapper-content centered">
          <div class="w-embed">
            <div class="resource-tab-layout">
              <aside class="resource-tab-rail">
                <CategoryTabs
                  ariaLabel="Glossary categories"
                  categories={grouped.map(({ subcategory }) => ({ label: subcategory }))}
                  idPrefix="glossary"
                  orientation="vertical"
                />
              </aside>
              <div id="glossary-content" class="glossary-content">
              {
                grouped.map(({ terms }, index) => (
                  <div
                    id={`glossary-panel-${index}`}
                    class="glossary-panel"
                    role="tabpanel"
                    aria-labelledby={`glossary-tab-${index}`}
                    data-index={index}
                    hidden={index !== 0}
                  >
                    {terms.map((item) => (
                      <div class="glossary-term">
                        <details>
                          <summary class="term">
                            <a id={termId(item.term)} href={`#${termId(item.term)}`}>
                              {item.term}
                            </a>
                            <span class="disclosure-icon" aria-hidden="true"></span>
                          </summary>
                          <div class="definition" set:html={item.definition} />
                        </details>
                      </div>
                    ))}
                  </div>
                ))
              }
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script>
    import { initCategoryTabs } from '../../scripts/category-tabs';

    const tabList = document.getElementById('glossary-tabs')!;
    const select = document.getElementById('glossary-select') as HTMLSelectElement;
    const content = document.getElementById('glossary-content')!;
    const panels = Array.from(content.querySelectorAll<HTMLElement>('.glossary-panel'));
    const categoryTabs = initCategoryTabs({
      tabList,
      panels,
      select,
      onChange: ({ animate, showPanels }) => {
        if (!animate) {
          showPanels();
          return;
        }
        content.classList.add('fade-out');
        window.setTimeout(() => {
          showPanels();
          content.classList.remove('fade-out');
        }, 300);
      },
    });

    // Clicking a term's link toggles its definition without moving the page.
    content.addEventListener('click', (e) => {
      const anchor = (e.target as HTMLElement).closest('summary.term a');
      if (!anchor) return;
      e.preventDefault();
      const details = anchor.closest('details')!;
      details.open = !details.open;
    });

    // Deep links (#term-id): jump to the right tab, open and scroll to the term.
    function openFromHash() {
      const term = window.location.hash.substring(1);
      if (!term) return;
      const anchor = document.getElementById(term);
      if (!anchor || !content.contains(anchor)) return;
      const panel = anchor.closest<HTMLElement>('.glossary-panel')!;
      categoryTabs.activate(Number(panel.dataset.index), { animate: false, source: 'programmatic' });
      const details = anchor.closest('details')!;
      details.open = true;
      anchor.scrollIntoView();
    }
    openFromHash();
    window.addEventListener('hashchange', openFromHash);
  </script>
</BaseLayout>
